### 15. 并发安全 (Google Style)

#### Context 传递

```go
// ❌ BAD - 不使用 context
func FetchUser(id string) (*User, error) {
    resp, err := http.Get("http://api.example.com/users/" + id)
    // ...
}

// ✅ GOOD - 第一个参数是 context
func FetchUser(ctx context.Context, id string) (*User, error) {
    req, err := http.NewRequestWithContext(ctx, "GET", 
        "http://api.example.com/users/"+id, nil)
    if err != nil {
        return nil, err
    }
    resp, err := http.DefaultClient.Do(req)
    // ...
}
```

**Context 规则**：
- 第一个参数命名为 `ctx`
- 不要将 context 存储在结构体中
- 不要传递 `nil` context，使用 `context.TODO()` 或 `context.Background()`

#### Goroutine 生命周期管理

```go
// ❌ BAD - goroutine 泄漏
func processItems(items []Item) {
    for _, item := range items {
        go processItem(item)  // 无法等待完成
    }
}

// ✅ GOOD - 使用 WaitGroup
func processItems(items []Item) {
    var wg sync.WaitGroup
    for _, item := range items {
        wg.Add(1)
        go func(item Item) {
            defer wg.Done()
            processItem(item)
        }(item)
    }
    wg.Wait()
}

// ✅ GOOD - 使用 errgroup（处理错误）
func processItems(ctx context.Context, items []Item) error {
    g, ctx := errgroup.WithContext(ctx)
    for _, item := range items {
        item := item  // 循环变量捕获
        g.Go(func() error {
            return processItem(ctx, item)
        })
    }
    return g.Wait()
}
```

#### Channel 关闭

```go
// ❌ BAD - 消费者关闭 channel
func worker(ch chan int) {
    for v := range ch {
        process(v)
    }
    close(ch)  // 错误：消费者不应该关闭
}

// ✅ GOOD - 生产者关闭 channel
func produce(ch chan<- int) {
    defer close(ch)  // 生产者负责关闭
    for i := 0; i < 10; i++ {
        ch <- i
    }
}

func consume(ch <-chan int) {
    for v := range ch {  // range 会在 channel 关闭时退出
        process(v)
    }
}
```

