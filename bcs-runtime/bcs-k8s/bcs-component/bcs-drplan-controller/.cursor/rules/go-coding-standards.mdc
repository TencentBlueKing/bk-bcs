## 9. 循环复杂度 (gocyclo)

**限制**：复杂度 ≤ 20

**策略**：提前返回、提取条件判断、使用状态机

```go
// ❌ BAD - 深层嵌套
func processRequest(req *Request) error {
    if req != nil {
        if req.Valid() {
            if req.Type == "A" {
                if req.Data != nil {
                    // 深层嵌套...
                }
            }
        }
    }
    return nil
}

// ✅ GOOD - 提前返回
func processRequest(req *Request) error {
    if req == nil {
        return errors.New("nil request")
    }
    if !req.Valid() {
        return errors.New("invalid request")
    }
    if req.Type != "A" {
        return errors.New("unsupported type")
    }
    if req.Data == nil {
        return errors.New("missing data")
    }
    
    // 主逻辑...
    return nil
}
```

